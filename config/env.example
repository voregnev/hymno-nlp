# config/env.example — скопируйте в .env и заполните

# PostgreSQL
PG_USER=hymn
PG_PASSWORD=hymn
PG_DSN=postgresql://hymn:hymn@localhost:5432/hymnography

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=hymn1234

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Anthropic (для LLM fallback)
ANTHROPIC_API_KEY=sk-ant-...

# W&B (для эксперимент-трекинга)
WANDB_API_KEY=...
WANDB_PROJECT=hymnography-nlp

# Scraper
AZBYKA_BASE_URL=https://azbyka.ru
SCRAPER_DELAY_SEC=1.5
SCRAPER_MAX_RETRIES=3

# Parser
LLM_ENABLED=true
LLM_BUDGET_PER_RUN=500

# Qdrant collections
QDRANT_COLLECTION_CU=hymns_cu
QDRANT_COLLECTION_GRC=hymns_grc
QDRANT_COLLECTION_MULTI=hymns_multilingual
